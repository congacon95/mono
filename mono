#!/usr/bin/env bash
# mono - Monorepo CLI entry point
# Usage: ./mono <command> [args]

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="$REPO_ROOT/.cursor/skills"

show_help() {
    cat << 'EOF'
mono - Monorepo CLI

Usage: ./mono <command> [args]

Commands:
  enforce help          List all portable stems
  enforce <stem>        Run a specific stem's gates
  check                 Run scope-based verification
  version               Show version info

Portable Stems:
  tpm-delegate          TPM / orchestrator role
  implement-slice       Stack implementer role
  review-pr             PR review role
  verify-pr             PR verification role
  po-product-docs       PO capsule format
  structure-and-naming  Structure / naming hygiene
  known-states          UI states / Playwright baselines
  ops-k8s               Kubernetes operations

Examples:
  ./mono enforce help
  ./mono enforce tpm-delegate
  ./mono enforce structure
  ./mono check
EOF
}

list_stems() {
    echo "=== Portable Stems ==="
    echo ""
    for stem_dir in "$SKILLS_DIR"/core-*/; do
        if [[ -d "$stem_dir" ]]; then
            stem_name=$(basename "$stem_dir")
            stem_name="${stem_name#core-}"
            
            # Check for SKILL.md to get description
            if [[ -f "$stem_dir/SKILL.md" ]]; then
                desc=$(head -3 "$stem_dir/SKILL.md" | grep "**Role:**" | sed 's/.*Role: //' | cut -d'-' -f1- | xargs)
                if [[ -n "$desc" ]]; then
                    printf "  %-25s %s\n" "$stem_name" "$desc"
                else
                    printf "  %-25s (no description)\n" "$stem_name"
                fi
            else
                printf "  %-25s (missing SKILL.md)\n" "$stem_name"
            fi
        fi
    done
    echo ""
    echo "Run './mono enforce <stem>' to execute a stem's gates"
}

run_enforce() {
    local stem="$1"
    
    if [[ -z "$stem" ]]; then
        echo "Error: stem name required"
        echo "Usage: ./mono enforce <stem>"
        echo "Run './mono enforce help' to list stems"
        exit 1
    fi
    
    if [[ "$stem" == "help" ]]; then
        list_stems
        return
    fi
    
    local stem_dir="$SKILLS_DIR/core-$stem"
    local enforce_script="$stem_dir/enforce.sh"
    
    if [[ ! -d "$stem_dir" ]]; then
        echo "Error: stem 'core-$stem' not found"
        list_stems
        exit 1
    fi
    
    if [[ ! -f "$enforce_script" ]]; then
        echo "Error: no enforce.sh found for stem 'core-$stem'"
        exit 1
    fi
    
    if [[ ! -x "$enforce_script" ]]; then
        chmod +x "$enforce_script"
    fi
    
    echo "Running gates for: core-$stem"
    echo ""
    bash "$enforce_script"
}

run_check() {
    echo "=== Running scope-based verification ==="
    echo ""
    
    # Run all stem gates
    for stem_dir in "$SKILLS_DIR"/core-*/; do
        if [[ -d "$stem_dir" ]]; then
            local enforce_script="$stem_dir/enforce.sh"
            if [[ -x "$enforce_script" ]]; then
                echo "---"
                bash "$enforce_script" || true
                echo ""
            fi
        fi
    done
    
    echo "=== Verification complete ==="
}

show_version() {
    echo "mono v1.0.0"
    echo "Monorepo CLI for portable stems enforcement"
}

# Main command router
if [[ $# -lt 1 ]]; then
    show_help
    exit 0
fi

command="$1"
shift

case "$command" in
    enforce)
        run_enforce "${1:-}"
        ;;
    check)
        run_check
        ;;
    help|--help|-h)
        show_help
        ;;
    version|--version|-v)
        show_version
        ;;
    *)
        echo "Error: unknown command '$command'"
        echo ""
        show_help
        exit 1
        ;;
esac
