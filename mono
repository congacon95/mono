#!/bin/bash

# Mono CLI - Monorepo orchestration tool
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVERS_LARAVEL="$SCRIPT_DIR/servers/laravel"
CLIENTS_WEB="$SCRIPT_DIR/clients/web"

usage() {
    cat << HELP
Mono CLI - Monorepo orchestration

Usage: ./mono <command> [options]

Commands:
  build       Build all projects or specific project (backend|frontend|all)
  dev         Start development servers (backend|frontend|both)
  test        Run test suites (backend|frontend|all)
  enforce     Run enforcement checks (help|<stem>)
  clean       Clean build artifacts

Examples:
  ./mono build all
  ./mono dev backend
  ./mono test frontend
  ./mono enforce known-states
HELP
}

cmd_build() {
    local target="${1:-all}"
    
    case "$target" in
        backend|laravel)
            echo "🔨 Building Laravel backend..."
            if [ -d "$SERVERS_LARAVEL" ]; then
                cd "$SERVERS_LARAVEL"
                composer install --no-interaction --prefer-dist --optimize-autoloader
                php artisan config:cache
                php artisan route:cache
                php artisan view:cache
                echo "✅ Laravel backend built successfully"
            else
                echo "❌ Laravel directory not found at $SERVERS_LARAVEL"
                exit 1
            fi
            ;;
        frontend|web)
            echo "🔨 Building frontend..."
            if [ -d "$CLIENTS_WEB" ]; then
                cd "$CLIENTS_WEB"
                npm ci
                npm run build
                echo "✅ Frontend built successfully"
            else
                echo "❌ Frontend directory not found at $CLIENTS_WEB"
                exit 1
            fi
            ;;
        all)
            echo "🔨 Building all projects..."
            cmd_build backend
            cmd_build frontend
            echo "✅ All projects built successfully"
            ;;
        *)
            echo "❌ Unknown build target: $target"
            echo "Valid targets: backend, frontend, all"
            exit 1
            ;;
    esac
}

cmd_dev() {
    local target="${1:-both}"
    
    case "$target" in
        backend|laravel)
            echo "🚀 Starting Laravel development server..."
            if [ -d "$SERVERS_LARAVEL" ]; then
                cd "$SERVERS_LARAVEL"
                php artisan serve --host=0.0.0.0 --port=8000
            else
                echo "❌ Laravel directory not found at $SERVERS_LARAVEL"
                exit 1
            fi
            ;;
        frontend|web)
            echo "🚀 Starting frontend development server..."
            if [ -d "$CLIENTS_WEB" ]; then
                cd "$CLIENTS_WEB"
                npm run dev
            else
                echo "❌ Frontend directory not found at $CLIENTS_WEB"
                exit 1
            fi
            ;;
        both)
            echo "🚀 Starting both development servers..."
            if [ ! -d "$SERVERS_LARAVEL" ] || [ ! -d "$CLIENTS_WEB" ]; then
                echo "❌ Required directories not found"
                exit 1
            fi
            
            # Start backend in background
            cd "$SERVERS_LARAVEL"
            php artisan serve --host=0.0.0.0 --port=8000 &
            BACKEND_PID=$!
            
            # Start frontend
            cd "$CLIENTS_WEB"
            npm run dev &
            FRONTEND_PID=$!
            
            echo "Backend PID: $BACKEND_PID"
            echo "Frontend PID: $FRONTEND_PID"
            echo "Press Ctrl+C to stop both servers"
            
            wait
            ;;
        *)
            echo "❌ Unknown dev target: $target"
            echo "Valid targets: backend, frontend, both"
            exit 1
            ;;
    esac
}

cmd_test() {
    local target="${1:-all}"
    
    case "$target" in
        backend|laravel)
            echo "🧪 Running Laravel backend tests..."
            if [ -d "$SERVERS_LARAVEL" ]; then
                cd "$SERVERS_LARAVEL"
                php artisan test --colors=always
                echo "✅ Backend tests completed"
            else
                echo "❌ Laravel directory not found at $SERVERS_LARAVEL"
                exit 1
            fi
            ;;
        frontend|web)
            echo "🧪 Running frontend tests..."
            if [ -d "$CLIENTS_WEB" ]; then
                cd "$CLIENTS_WEB"
                npm run test
                echo "✅ Frontend tests completed"
            else
                echo "❌ Frontend directory not found at $CLIENTS_WEB"
                exit 1
            fi
            ;;
        e2e|playwright)
            echo "🧪 Running Playwright E2E tests..."
            if [ -d "$CLIENTS_WEB" ]; then
                cd "$CLIENTS_WEB"
                npx playwright test
                echo "✅ E2E tests completed"
            else
                echo "❌ Frontend directory not found at $CLIENTS_WEB"
                exit 1
            fi
            ;;
        all)
            echo "🧪 Running all test suites..."
            set +e
            cmd_test backend
            BACKEND_RESULT=$?
            cmd_test frontend
            FRONTEND_RESULT=$?
            cmd_test e2e
            E2E_RESULT=$?
            set -e
            
            if [ $BACKEND_RESULT -eq 0 ] && [ $FRONTEND_RESULT -eq 0 ] && [ $E2E_RESULT -eq 0 ]; then
                echo "✅ All test suites passed"
            else
                echo "⚠️  Some test suites failed"
                exit 1
            fi
            ;;
        *)
            echo "❌ Unknown test target: $target"
            echo "Valid targets: backend, frontend, e2e, all"
            exit 1
            ;;
    esac
}

cmd_enforce() {
    local stem="${1:-help}"
    
    if [ "$stem" = "help" ]; then
        echo "Available stems:"
        echo "  - known-states: Verify known UI states and Playwright baselines"
        echo "  - structure: Verify project structure and naming conventions"
        echo "  - po-capsules: Verify PO capsule format and links"
        echo ""
        echo "Usage: ./mono enforce <stem>"
        return 0
    fi
    
    SKILLS_DIR="$SCRIPT_DIR/.cursor/skills"
    
    case "$stem" in
        known-states)
            if [ -f "$SKILLS_DIR/core-known-states/enforce.sh" ]; then
                bash "$SKILLS_DIR/core-known-states/enforce.sh"
            else
                echo "⚠️  Known-states enforce script not found"
            fi
            ;;
        structure)
            if [ -f "$SKILLS_DIR/core-structure-and-naming/enforce.sh" ]; then
                bash "$SKILLS_DIR/core-structure-and-naming/enforce.sh"
            else
                echo "⚠️  Structure enforce script not found"
            fi
            ;;
        po-capsules)
            if [ -f "$SKILLS_DIR/core-po-product-docs/enforce.sh" ]; then
                bash "$SKILLS_DIR/core-po-product-docs/enforce.sh"
            else
                echo "⚠️  PO capsules enforce script not found"
            fi
            ;;
        *)
            echo "❌ Unknown stem: $stem"
            echo "Run './mono enforce help' for available stems"
            exit 1
            ;;
    esac
}

cmd_clean() {
    echo "🧹 Cleaning build artifacts..."
    
    if [ -d "$SERVERS_LARAVEL" ]; then
        cd "$SERVERS_LARAVEL"
        rm -rf vendor storage/framework/cache/* storage/framework/views/* storage/framework/sessions/* bootstrap/cache/*.php
        echo "  - Laravel cache cleaned"
    fi
    
    if [ -d "$CLIENTS_WEB" ]; then
        cd "$CLIENTS_WEB"
        rm -rf node_modules dist build .next
        echo "  - Frontend build artifacts cleaned"
    fi
    
    rm -rf "$SCRIPT_DIR/node_modules" "$SCRIPT_DIR/playwright-report" "$SCRIPT_DIR/test-results"
    echo "  - Root build artifacts cleaned"
    
    echo "✅ Clean complete"
}

# Main command router
case "${1:-}" in
    build)
        shift
        cmd_build "$@"
        ;;
    dev)
        shift
        cmd_dev "$@"
        ;;
    test)
        shift
        cmd_test "$@"
        ;;
    enforce)
        shift
        cmd_enforce "$@"
        ;;
    clean)
        shift
        cmd_clean "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    "")
        usage
        exit 1
        ;;
    *)
        echo "❌ Unknown command: $1"
        usage
        exit 1
        ;;
esac
